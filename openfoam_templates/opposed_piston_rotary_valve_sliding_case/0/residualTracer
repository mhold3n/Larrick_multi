FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      residualTracer;
}

dimensions      [0 0 0 0 0 0 0];
internalField   uniform {{handoff_residual_tracer}};
boundaryField
{
    inlet { type fixedValue; value uniform 0; }
    outlet { type zeroGradient; }
    walls { type zeroGradient; }
    cylinder { type zeroGradient; }
    intakeValve { type zeroGradient; }
    exhaustValveLeft { type zeroGradient; }
    exhaustValveRight { type zeroGradient; }
    "AMI_.*" { type cyclicAMI; }
}
