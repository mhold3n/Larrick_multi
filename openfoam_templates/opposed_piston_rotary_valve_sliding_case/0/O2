FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      O2;
}

dimensions      [0 0 0 0 0 0 0];

internalField   uniform {{handoff_species_O2}};

boundaryField
{
    inlet
    {
        type            inletOutlet;
        inletValue      uniform {{handoff_species_O2}};
        value           uniform {{handoff_species_O2}};
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            zeroGradient;
    }
    cylinder
    {
        type            zeroGradient;
    }
    intakeValve
    {
        type            zeroGradient;
    }
    exhaustValveLeft
    {
        type            zeroGradient;
    }
    exhaustValveRight
    {
        type            zeroGradient;
    }
    "AMI_.*"
    {
        type            cyclicAMI;
    }
}
